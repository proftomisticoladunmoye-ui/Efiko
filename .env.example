# Efiko Gateway — environment.
# Without WhatsApp credentials the gateway runs in MOCK mode (fully testable locally).
# Fill these in to go LIVE on the WhatsApp Business Cloud API — no code changes needed.

PORT=4100

# Anthropic — AI Processing Engine (Stage 5+). Get a key from the Anthropic Console.
# NEVER commit a real key; this .env is gitignored. Paste your key locally only.
ANTHROPIC_API_KEY=
EFIKO_AUTHOR_MODEL=claude-opus-4-8
EFIKO_FAST_MODEL=claude-haiku-4-5

# Voice Tutor (Stage 6). Provider is swappable: deepgram (default) or azure.
# Efiko caches each note, so cost stays near zero. Leave keys blank → voice placeholder.
EFIKO_TTS_PROVIDER=deepgram
# Deepgram Aura voice (aura-asteria-en, aura-luna-en, aura-orion-en, ...)
EFIKO_TTS_VOICE=aura-asteria-en
DEEPGRAM_API_KEY=
# Azure alternative (African-accent voices: en-KE-AsiliaNeural, en-NG-EzinneNeural, ...)
# Set EFIKO_TTS_PROVIDER=azure and EFIKO_TTS_VOICE to one of those, then fill these:
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=Efiko-verify
WHATSAPP_GRAPH_URL=https://graph.facebook.com/v19.0

# Institution Admin (Phase B). ADMIN_SECRET signs login tokens (use a long random
# string). ADMIN_MASTER_KEY gates creating institution accounts (keep private).
ADMIN_SECRET=
ADMIN_MASTER_KEY=

# SMS Learning Assistant (Stage 10) — 2G fallback. Mock by default; set
# SMS_PROVIDER=africastalking + AT_* to go live (best fit for African markets).
SMS_PROVIDER=mock
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Public base URL where /assets/*.svg are served (for WhatsApp image links).
PUBLIC_BASE_URL=
